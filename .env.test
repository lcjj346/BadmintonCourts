# Jest-only database — same local Postgres container as .env, but a dedicated
# "badmintonsg_test" database so `npm test` (whose resetDb() wipes every table)
# can never touch the dev app's data. A separate database (not just a schema)
# because some generated migrations hardcode the "public" schema. Jest runs
# with NODE_ENV=test, which makes Next's env loader prefer this file over
# .env; in CI the workflow-level env vars are already set in the process and
# always win over any file. No secrets here — these are the same throwaway
# localhost credentials as .env.example.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/badmintonsg_test"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/badmintonsg_test"
IP_HASH_SALT="test-salt"
