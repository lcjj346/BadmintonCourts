{
  "name": "badmintonsg",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && if [ \"$VERCEL_ENV\" = \"production\" ]; then prisma migrate deploy; fi && next build",
    "start": "dotenv -e .env -- next start",
    "lint": "eslint",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:load": "playwright test --config=playwright.load.config.ts",
    "test:load:prod": "dotenv -e .env.production.local -- playwright test --config=playwright.load.prod.config.ts",
    "prod:migrate": "dotenv -e .env.production.local -- npx prisma migrate deploy",
    "prod:seed": "dotenv -e .env.production.local -- npx prisma db seed",
    "loadtest:seed": "ts-node --transpile-only --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/loadTestSeed.ts",
    "loadtest:cleanup": "ts-node --transpile-only --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/loadTestSeed.ts --cleanup",
    "loadtest:seed:prod": "dotenv -e .env.production.local -- npm run loadtest:seed --",
    "loadtest:cleanup:prod": "dotenv -e .env.production.local -- npm run loadtest:cleanup"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.66.0",
    "@vercel/analytics": "^2.0.1",
    "dayjs": "^1.11.21",
    "lenis": "^1.3.25",
    "next": "15.5.20",
    "pino": "^9.14.0",
    "prisma": "^6.19.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^3.25.76"
  },
  "prisma": {
    "seed": "ts-node --transpile-only --compiler-options {\"module\":\"CommonJS\",\"moduleResolution\":\"node\"} prisma/seed.ts"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
