generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Region {
  NORTH
  SOUTH
  EAST
  WEST
  CENTRAL
}

enum VenueType {
  SPORTS_HALL
  COMMUNITY_CENTRE
  SCHOOL
  OTHER
}

enum ListingStatus {
  AVAILABLE
  SOLD
  EXPIRED
}

enum SessionStatus {
  OPEN
  FILLED
  EXPIRED
}

enum SkillLevel {
  LOW_BEGINNER
  MID_BEGINNER
  HIGH_BEGINNER
  LOW_INTERMEDIATE
  MID_INTERMEDIATE
  HIGH_INTERMEDIATE
  ADVANCED
}

enum RateAction {
  REVEAL
  CREATE
  REPORT
  PRESENCE
}

model Venue {
  id               String    @id @default(uuid())
  name             String    @unique
  address          String
  postalCode       String
  region           Region
  venueType        VenueType
  availabilityNote String?   // e.g. "Weekends & school holidays only" for DUS schools
  listings         Listing[]
  sessions         GameSession[]
}

model Listing {
  id              String        @id @default(uuid())
  venueId         String?                          // null when customVenueName is set instead
  venue           Venue?        @relation(fields: [venueId], references: [id])
  customVenueName String?                          // set instead of venueId when the poster's venue isn't in our curated list
  customRegion    Region?                          // region for a custom venue — ignored when venueId is set
  date            DateTime      @db.Date           // SGT calendar date — see §5
  startTime       String                           // "08:00" SGT wall-clock
  endTime         String                           // "10:00"
  priceCents      Int?                             // 0 = free, null = negotiable
  notes           String?
  phone           String?                          // nullable: scrubbed post-expiry (§7). NEVER in public selects
  telegramHandle  String?                          // alternative to phone (at least one required) — same reveal/scrub rules
  status          ListingStatus @default(AVAILABLE)
  closedAt        DateTime?                        // when marked SOLD; null again if reopened — drives the 1hr auto-expiry
  batchToken      String        @default(uuid())   // shared by every post created in the same submission — the manage-link secret
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([date, status])
  @@index([venueId])
  @@index([batchToken])
  @@index([phone, status])          // active-post-cap count (contactWhere) — full scan-free at scale
  @@index([telegramHandle, status]) // same, for Telegram-only posters
  @@index([status, closedAt])       // sweepExpired's 1hr-after-close check
}

model GameSession {
  id                  String        @id @default(uuid())
  venueId             String?                          // null when customVenueName is set instead
  venue               Venue?        @relation(fields: [venueId], references: [id])
  customVenueName     String?                          // set instead of venueId when the poster's venue isn't in our curated list
  customRegion        Region?                          // region for a custom venue — ignored when venueId is set
  date                DateTime      @db.Date
  startTime           String
  endTime             String
  playersNeeded       Int
  skillMin            SkillLevel
  skillMax            SkillLevel
  pricePerPlayerCents Int?                // 0 = free, null = split/negotiable
  notes               String?
  phone               String?             // same scrubbing + select rules as Listing
  telegramHandle      String?             // alternative to phone (at least one required)
  status              SessionStatus @default(OPEN)
  closedAt            DateTime?                        // when marked FILLED; null again if reopened — drives the 1hr auto-expiry
  batchToken          String        @default(uuid())  // shared by every post created in the same submission — the manage-link secret
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([date, status])
  @@index([venueId])
  @@index([batchToken])
  @@index([phone, status])
  @@index([telegramHandle, status])
  @@index([status, closedAt])       // sweepExpired's 1hr-after-close check
}

model RateLimitEvent {
  id        String     @id @default(uuid())
  ipHash    String                        // SHA-256(ip + server salt); raw IPs never stored
  action    RateAction
  targetId  String?                       // listing/session id for per-target reveal limits
  createdAt DateTime   @default(now())

  @@index([ipHash, action, createdAt])
}

model ReportFlag {
  id         String   @id @default(uuid())
  targetType String                       // "listing" | "session"
  targetId   String
  ipHash     String
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
}

model VenueSuggestion {
  id        String   @id @default(uuid())
  name      String
  details   String?
  createdAt DateTime @default(now())
}

model Presence {
  id       String   @id            // random client-generated UUID, no PII
  lastSeen DateTime @default(now())
}
